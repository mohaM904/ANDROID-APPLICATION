import 'dart:math';
import 'package:flutter/material.dart';
import 'package:sensors_plus/sensors_plus.dart';
import 'package:vibration/vibration.dart';
import 'package:audioplayers/audioplayers.dart';

void main() => runApp(const SafeWalkApp());



class SafeWalkApp extends StatelessWidget {
  const SafeWalkApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'SafeWalk Pro',
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        useMaterial3: true,
        colorScheme: ColorScheme.fromSeed(seedColor: Colors.blueAccent),
      ),
      home: const SafeWalkHomePage(),
    );
  }
}

class SafeWalkHomePage extends StatefulWidget {
  const SafeWalkHomePage({super.key});

  @override
  State<SafeWalkHomePage> createState() => _SafeWalkHomePageState();
}

class _SafeWalkHomePageState extends State<SafeWalkHomePage> with TickerProviderStateMixin {
  final AudioPlayer _audioPlayer = AudioPlayer();
  
  // App State
  bool _isWalking = false;
  bool _isPhoneInUse = false;
  bool _alertTriggered = false;
  bool _isDemoRunning = false;
  
  // Real-world calibration
  double _walkingThreshold = 2.5; // Sensitivity for steps
  
  late AnimationController _animationController;
  late Animation<double> _scaleAnimation;

  @override
  void initState() {
    super.initState();
    _animationController = AnimationController(
      duration: const Duration(milliseconds: 400),
      vsync: this,
    );
    _scaleAnimation = Tween<double>(begin: 1.0, end: 1.1).animate(
      CurvedAnimation(parent: _animationController, curve: Curves.easeInOut),
    );

    // 1. Walking Detection (Using User Accelerometer - ignores gravity)
    userAccelerometerEventStream().listen((UserAccelerometerEvent event) {
      if (_isDemoRunning) return;
      
      // Calculate magnitude of movement
      double magnitude = sqrt(event.x * event.x + event.y * event.y + event.z * event.z);
      
      bool walking = magnitude > _walkingThreshold;
      if (walking != _isWalking) {
        setState(() => _isWalking = walking);
        if (walking) _checkUnsafeUsage();
      }
    });

    // 2. Phone Usage Detection (Using Tilt Angle)
    accelerometerEventStream().listen((AccelerometerEvent event) {
      if (_isDemoRunning) return;
      
      // Calculate pitch (tilt) - detect if phone is held up to face
      // Values around 4-8 on the Y axis usually mean the phone is tilted toward the user
      bool tiltedUp = event.y > 3.0 && event.y < 9.0;
      
      if (tiltedUp != _isPhoneInUse) {
        setState(() => _isPhoneInUse = tiltedUp);
        if (tiltedUp) _checkUnsafeUsage();
      }
    });
  }

  void _checkUnsafeUsage() {
    if (_isWalking && _isPhoneInUse && !_alertTriggered) {
      _triggerAlert();
    }
  }

  void _triggerAlert() {
    if (_alertTriggered) return;
    setState(() => _alertTriggered = true);
    _animationController.repeat(reverse: true);
    _audioPlayer.play(AssetSource('alert.mp3'));
    Vibration.vibrate(pattern: [0, 500, 200, 500]); // SOS style vibration
  }

  void _stopAlert() {
    setState(() {
      _alertTriggered = false;
      _isWalking = false;
      _isPhoneInUse = false;
      _isDemoRunning = false;
    });
    _animationController.stop();
    _animationController.reset();
    _audioPlayer.stop();
  }

  void _runDemoSequence() async {
    if (_isDemoRunning) return;
    _stopAlert();
    setState(() => _isDemoRunning = true);
    await Future.delayed(const Duration(seconds: 1));
    setState(() => _isWalking = true);
    await Future.delayed(const Duration(seconds: 2));
    setState(() => _isPhoneInUse = true);
    _checkUnsafeUsage();
  }

  @override
  void dispose() {
    _animationController.dispose();
    _audioPlayer.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: _alertTriggered ? Colors.red.shade900 : Colors.grey.shade100,
      appBar: AppBar(
        title: const Text('SafeWalk Physical', style: TextStyle(fontWeight: FontWeight.bold)),
        backgroundColor: _alertTriggered ? Colors.black : Colors.blueAccent,
        foregroundColor: Colors.white,
      ),
      body: Column(
        children: [
          Container(
            padding: const EdgeInsets.all(24),
            child: Column(
              children: [
                // Status Shield
                ScaleTransition(
                  scale: _scaleAnimation,
                  child: Container(
                    width: double.infinity,
                    padding: const EdgeInsets.symmetric(vertical: 40),
                    decoration: BoxDecoration(
                      color: _alertTriggered ? Colors.redAccent : Colors.white,
                      borderRadius: BorderRadius.circular(30),
                      boxShadow: [BoxShadow(color: Colors.black12, blurRadius: 15)],
                    ),
                    child: Column(
                      children: [
                        Icon(
                          _alertTriggered ? Icons.warning_rounded : Icons.security_rounded,
                          size: 100,
                          color: _alertTriggered ? Colors.white : Colors.blueAccent,
                        ),
                        const SizedBox(height: 16),
                        Text(
                          _alertTriggered ? "STOP WALKING!" : "MONITORING...",
                          style: TextStyle(
                            fontSize: 28,
                            fontWeight: FontWeight.w900,
                            color: _alertTriggered ? Colors.white : Colors.blueGrey,
                          ),
                        ),
                      ],
                    ),
                  ),
                ),
                const SizedBox(height: 24),
                
                // Sensor Tiles
                Row(
                  children: [
                    _sensorTile("Walking", Icons.directions_run, _isWalking, Colors.orange),
                    const SizedBox(width: 16),
                    _sensorTile("Reading", Icons.visibility, _isPhoneInUse, Colors.purple),
                  ],
                ),
                
                const SizedBox(height: 32),
                
                // Sensitivity Slider (For Real Devices)
                if (!_alertTriggered) ...[
                  const Text("Sensor Sensitivity", style: TextStyle(color: Colors.grey, fontWeight: FontWeight.bold)),
                  Slider(
                    value: _walkingThreshold,
                    min: 1.0,
                    max: 5.0,
                    onChanged: (val) => setState(() => _walkingThreshold = val),
                  ),
                ],

                // Control Buttons
                if (_alertTriggered)
                  _largeButton("DISMISS ALERT", Icons.check_circle, Colors.white, Colors.red, _stopAlert)
                else ...[
                  _largeButton("START DEMO", Icons.play_arrow, Colors.blueAccent, Colors.white, _runDemoSequence),
                  const SizedBox(height: 12),
                  _largeButton("MANUAL TEST", Icons.vibration, Colors.blueGrey, Colors.white, _triggerAlert),
                ],
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _sensorTile(String title, IconData icon, bool active, Color color) {
    return Expanded(
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 300),
        padding: const EdgeInsets.all(20),
        decoration: BoxDecoration(
          color: active ? color : Colors.white,
          borderRadius: BorderRadius.circular(20),
          boxShadow: [if (active) BoxShadow(color: color.withOpacity(0.4), blurRadius: 10)],
        ),
        child: Column(
          children: [
            Icon(icon, color: active ? Colors.white : Colors.grey, size: 35),
            const SizedBox(height: 8),
            Text(title, style: TextStyle(color: active ? Colors.white : Colors.grey, fontWeight: FontWeight.bold)),
          ],
        ),
      ),
    );
  }

  Widget _largeButton(String title, IconData icon, Color bg, Color fg, VoidCallback tap) {
    return SizedBox(
      width: double.infinity,
      height: 65,
      child: ElevatedButton.icon(
        onPressed: tap,
        icon: Icon(icon, color: fg),
        label: Text(title, style: TextStyle(color: fg, fontSize: 18, fontWeight: FontWeight.bold)),
        style: ElevatedButton.styleFrom(backgroundColor: bg, shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20))),
      ),
    );
  }
}
